# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Amadeus Flight API (https://developers.amadeus.com — free tier available)
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here

# Email configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here   # Gmail: use an App Password, not your main password
ALERT_EMAIL_FROM=your_email@gmail.com
ALERT_EMAIL_TO=recipient@example.com  # Comma-separated for multiple recipients

# Monitoring
CHECK_INTERVAL_MINUTES=60   # How often to check prices (default: every hour)
